# Amazon/Alexa account
#
# RECOMMENDED: leave AMAZON_EMAIL / AMAZON_PASSWORD blank and connect your
# account via the web UI at http://nfc-jukebox.local:8080/setup. That flow
# signs in through YOUR browser (passkey supported) and stores only a
# revocable device token on the Pi — your password never touches this device.
AMAZON_EMAIL=
AMAZON_PASSWORD=

# Amazon marketplace domain suffix (com, co.uk, de, ...). Most users: com
AMAZON_DOMAIN=com

# Name of the Echo/Alexa device exactly as it appears in the Alexa app
ALEXA_DEVICE_NAME=Kitchen Echo

# Default Alexa command template. Can also be edited in the web UI.
ALEXA_COMMAND_TEMPLATE=play the album {album} by {artist}

# Where reusable Amazon login/cookie data is stored.
ALEXA_LOGIN_DATA_FILE=/opt/nfc-jukebox/data/.alexa-login-data.json

# SQLite database path
NFC_JUKEBOX_DB=/opt/nfc-jukebox/data/nfc-jukebox.sqlite3

# NFC duplicate-scan suppression window (seconds)
NFC_RESCAN_COOLDOWN_SECONDS=5

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Optional local web UI protection. If blank, no password is required.
WEB_UI_PASSWORD=

# GPIO
LED_PIN=24

# Physical playback buttons arrive as USB keyboard keystrokes (a keyboard
# emulator). Map characters to actions. Default matches the original firmware
# (p = play/pause, n = next, b = previous).
BUTTON_KEY_MAP=p=playpause,n=next,b=previous
